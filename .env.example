# Canonical public URL — defaults to https://voltanyc.org if not set
NEXT_PUBLIC_SITE_URL=https://voltanyc.org

# Google Apps Script Web App URL (deployed as public web app)
# Deploy SheetsLogger.gs and paste the URL here
NEXT_PUBLIC_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# The Google Drive Folder ID for resume uploads (optional)
DRIVE_FOLDER_ID=your_folder_id_here

# Firebase Admin SDK — required for the public interview booking page.
# Get these from Firebase Console → Project Settings → Service Accounts → Generate new private key.
# FIREBASE_PRIVATE_KEY must preserve literal \n characters (Vercel handles this automatically).
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Abuse guardrails (server-side)
# Form submit limits
FORM_RATE_LIMIT_PER_IP=8
FORM_RATE_LIMIT_PER_EMAIL=5
FORM_RATE_LIMIT_WINDOW_SEC=3600

# Resume upload limits
RESUME_UPLOAD_RATE_LIMIT_PER_IP=5
RESUME_UPLOAD_RATE_LIMIT_WINDOW_SEC=3600

# Member signup limits
SIGNUP_RATE_LIMIT_PER_IP=5
SIGNUP_RATE_LIMIT_PER_EMAIL=3
SIGNUP_RATE_LIMIT_WINDOW_SEC=86400

# Outgoing email (SMTP)
# Primary account — used for most automated emails (e.g. info@voltanyc.org alias on volta.newyork@gmail.com)
# For Gmail: SMTP_USER = your Gmail address, SMTP_PASS = app password, EMAIL_FROM = your alias
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=volta.newyork@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=info@voltanyc.org
EMAIL_REPLY_TO=info@voltanyc.org

# Secondary account — used when sending from a different alias (e.g. ethan@voltanyc.org)
# SMTP_SECONDARY_FROM_ADDRESSES=ethan@voltanyc.org
# SMTP_USER_SECONDARY=ethanzhangvolta@gmail.com
# SMTP_PASS_SECONDARY=your-app-password

# Allowed "from" addresses (comma-separated) for manual sends (team emails, acceptance emails)
TEAM_EMAIL_ALLOWED_FROM=info@voltanyc.org,ethan@voltanyc.org
